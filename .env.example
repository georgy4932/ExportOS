# Copy to .env.local and fill in values before running `npm run verify` or `npm run api`.
#
# Direct Postgres connection (bypasses Kong/PostgREST/Storage).
# Local Supabase default — port 54322 is the Postgres container:
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# JWT secret used to sign and verify bearer tokens.
# Any string works for local dev; use a long random secret in production.
JWT_SECRET=local-dev-secret-change-in-production

# Seeded exporter ID from supabase/seed.sql (AKOBO AGRI-EXPORT COMPANY LTD):
VERIFY_EXPORTER_ID=b0b00001-0000-0000-0000-000000000001

# Seeded local_users credentials (from supabase/seed.sql §9b):
VERIFY_EMAIL=operator@akoboexports.ng
VERIFY_PASSWORD=dev-seed-password

# API server port (npm run api / npm start):
PORT=3000

# API base URL used by verify scripts:
API_URL=http://localhost:3000

# ── Deployment (Railway / Render) ─────────────────────────────────────────────

# Deployed Vercel frontend URL — set this on Railway/Render so the API allows
# cross-origin requests from the Vercel domain.
# Example: https://exportos.vercel.app
# Leave unset for local dev (same-origin requests don't need CORS headers).
ALLOWED_ORIGIN=

# ── Deployment (Vercel) ───────────────────────────────────────────────────────

# Railway or Render API URL — set this in Vercel project environment variables.
# The build step writes it into public/config.js so the browser knows where to send API calls.
# Example: https://exportos-api.up.railway.app
API_BASE_URL=
